{
  "name": "makina-x",
  "version": "v1.0.0",
  "description": "MakinaX contracts",
  "repository": "https://github.com/MakinaHQ/makina-x.git",
  "author": "MakinaHQ",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@openzeppelin/merkle-tree": "1.0.8",
    "ethers": "6.16.0",
    "prettier": "3.8.1",
    "solhint": "6.2.1"
  },
  "type": "module",
  "scripts": {
    "build:ir": "FOUNDRY_PROFILE=ir forge build",
    "lint": "yarn lint:sol && yarn prettier:check",
    "lint:sol": "forge fmt --check && yarn solhint \"{script,src,test}/**/*.sol\"",
    "prettier:check": "prettier --check \"**/*.{js,json,md,yml}\" \"!script/deployments/outputs/**/*\"",
    "prettier:write": "prettier --write \"**/*.{js,json,md,yml}\" \"!script/deployments/outputs/**/*\"",
    "coverage": "FOUNDRY_FUZZ_RUNS=32 forge coverage --no-match-coverage \"(script|test)\"",
    "coverage:debug": "FOUNDRY_FUZZ_RUNS=32 forge coverage --no-match-coverage \"(script|test)\" --report debug",
    "genMerkleDataMock": "node script/merkle/generateMerkleTreeDataMock.js"
  }
}
